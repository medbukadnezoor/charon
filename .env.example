TELEGRAM_BOT_TOKEN=
SHADOW_TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_TOPIC_ID=

# Signal server — contact maintainer for access
SIGNAL_SERVER_URL=https://api.thecharon.xyz/api
SIGNAL_SERVER_KEY=
SIGNAL_POLL_MS=30000

# Helius RPC — required for live execution; free tier works for dry_run
HELIUS_API_KEY=
SOLANA_RPC_URL=
SOLANA_WS_URL=
PUMP_HELIUS_RPC_URL=
PUMP_HELIUS_WS_URL=

# GMGN enrichment — set GMGN_ENABLED=false to skip (falls back to Jupiter data)
GMGN_ENABLED=true
GMGN_API_KEY=
GMGN_REQUEST_DELAY_MS=2500
GMGN_MAX_RETRIES=2

DB_PATH=./charon.sqlite
TRADING_MODE=dry_run

# Live / confirm execution — wallet + Jupiter API key required
SOLANA_PRIVATE_KEY=
JUPITER_API_KEY=

# Optional observation telemetry provider key.
# The collector accepts BIRDEYE_API_KEY, BIRDEYE_BDS_API_KEY, BDS_API_KEY, or BIRDEYE_KEY.
BIRDEYE_API_KEY=
TELEMETRY_OHLCV_INTERVAL=1m
JUPITER_SWAP_BASE_URL=https://api.jup.ag/swap/v2
LIVE_MIN_SOL_RESERVE=0.02

# LLM - provider order is configurable. Primary defaults to MiMo when a MiMo key
# is present, then falls back to the VPS-local CLIProxyAPI endpoint.
ENABLE_LLM=true
LLM_PROVIDER_ORDER=mimo,cliproxy
MIMO_LLM_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1
MIMO_LLM_MODEL=mimo-v2.5-pro
# Accepted key names: MIMO_LLM_API_KEY, MIMO_API_KEY, XIAOMIMIMO_API_KEY,
# MIMO_TOKEN_PLAN_API_KEY, or TOKEN_PLAN_API_KEY.
MIMO_LLM_API_KEY=
CLIPROXY_LLM_BASE_URL=http://127.0.0.1:8317/v1
CLIPROXY_LLM_MODEL=gpt-5.5
CLIPROXY_LLM_API_KEY=NO_API_KEY
# Legacy single-provider knobs remain supported as LLM_PROVIDER_ORDER=legacy.
LLM_BASE_URL=http://127.0.0.1:8317/v1
LLM_API_KEY=NO_API_KEY
LLM_MODEL=gpt-5.5
LLM_REASONING_EFFORT=low
# Shadow uses the free endpoint first and CLIProxy fallback through LLM_PROVIDER_ORDER=legacy,cliproxy.
SHADOW_LLM_BASE_URL=https://integrate.api.nvidia.com/v1
SHADOW_LLM_API_KEY=
SHADOW_LLM_MODEL=meta/llama-4-maverick-17b-128e-instruct
SHADOW_LLM_REASONING_EFFORT=
LLM_TIMEOUT_MS=90000
LLM_CANDIDATE_PICK_COUNT=10
LLM_CANDIDATE_MAX_AGE_MS=600000
MAX_OPEN_POSITIONS=3

MIN_FEE_CLAIM_SOL=2
GRADUATED_POLL_MS=30000
GRADUATED_LOOKBACK_MS=7200000
TRENDING_POLL_MS=60000
TRENDING_LOOKBACK_MS=600000
TRENDING_ENABLED=true
TRENDING_SOURCE=jupiter
TRENDING_ALLOW_DEGEN=false
TRENDING_INTERVAL=5m
TRENDING_LIMIT=100
TRENDING_ORDER_BY=volume
TRENDING_MIN_VOLUME_USD=0
TRENDING_MIN_SWAPS=0
TRENDING_MAX_RUG_RATIO=0.3
TRENDING_MAX_BUNDLER_RATE=0.5
GMGN_CACHE_TTL_MS=300000
POSITION_CHECK_MS=10000
