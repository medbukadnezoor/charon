# === Required ===
# Copy this file to .env for local use.
# On VPS, use HARVESTER_DB_PATH=/opt/trading-data/harvester.db.
# Do not add Charon wallet keys, Telegram tokens, or trading secrets here.
GMGN_API_KEY=

# === Optional - OKX (set all 4 or none) ===
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_PROJECT_ID=

# === Optional - trade history (Helius) ===
HELIUS_API_KEY=

# === Optional - trade context (Birdeye) ===
BIRDEYE_API_KEY=

# === Storage (override for VPS layout) ===
HARVESTER_DB_PATH=./data/harvester.db
